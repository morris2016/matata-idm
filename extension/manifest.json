{
  "manifest_version": 3,
  "name": "matata download helper",
  "short_name": "matata",
  "version": "0.9.5",
  "description": "Send Chrome downloads to matata — fast segmented downloads with resume, HLS / DASH capture, and a clean queue.",
  "minimum_chrome_version": "109",

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "downloads",
    "storage",
    "cookies",
    "nativeMessaging",
    "webRequest",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*",
        "*://player.vimeo.com/*",
        "*://vimeo.com/*"
      ],
      "js": ["yt-extract.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*",
        "*://player.vimeo.com/*",
        "*://vimeo.com/*"
      ],
      "js": ["sniff-overlay.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_title": "matata",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "matata@matata.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
